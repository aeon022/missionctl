---
import Layout from '../components/Layout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';

const mcpTools = [
  { name: "today_tasks", desc: "Get tasks due today or overdue — good for morning briefings" },
  { name: "week_tasks", desc: "Get tasks due this week (Monday to Sunday)" },
  { name: "list_tasks", desc: "List tasks from the local cache, filtered by list or status" },
  { name: "create_task", desc: "Create a new task in Apple Reminders" },
  { name: "complete_task", desc: "Mark a task as completed in Apple Reminders" },
  { name: "delete_task", desc: "Delete a task from Apple Reminders" },
  { name: "sync", desc: "Sync tasks from Apple Reminders into the local cache" },
];
const features = [
  { title: "Apple Reminders Sync", desc: "Two-way sync with Apple Reminders. Your tasks stay in the Apple ecosystem, accessible from iPhone, iPad, and Mac." },
  { title: "Pomodoro Timer", desc: "Built-in Pomodoro timer with configurable work/break intervals. Track focus sessions per task." },
  { title: "Batch Operations", desc: "Complete, delete, or reschedule multiple tasks at once. Keyboard-driven TUI makes bulk edits fast." },
  { title: "Background Daemon", desc: "Runs as a daemon to keep tasks synced and trigger Pomodoro notifications — no terminal window required." },
];
---

<Layout
  title="taskctl — Tasks from your Terminal"
  description="taskctl — Manage tasks, sync with Apple Reminders, run a Pomodoro timer. 7 MCP tools for Claude Desktop."
  type="software"
  appName="taskctl"
  appPrice="9"
>
  <!-- HERO -->
  <section style="padding: 10rem 1.5rem 5rem; max-width: 1100px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="hero-grid">
      <div>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #f59e0b; margin-bottom: 1rem; letter-spacing: 0.1em; text-transform: uppercase;">
          missionctl suite &middot; macOS
        </div>
        <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.03em; color: #e2e8f0; margin: 0 0 1rem;">
          <span style="font-family: 'JetBrains Mono', monospace; color: #f59e0b;">taskctl</span>
        </h1>
        <p style="font-size: 1.25rem; font-weight: 600; color: #e2e8f0; margin: 0 0 0.75rem;">Tasks from your Terminal</p>
        <p style="color: #718096; font-size: 1rem; line-height: 1.65; margin: 0 0 2rem;">Manage tasks with Apple Reminders sync, built-in Pomodoro timer, and background daemon. 7 MCP tools for AI-powered task management.</p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
            style="display: inline-flex; align-items: center; padding: 0.75rem 1.25rem; background: #f59e0b; color: #0a0a0f; border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 700; text-decoration: none; transition: all 0.15s;"
            class="cta-primary">
            Get taskctl &mdash; $9
          </a>
          <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
            style="display: inline-flex; align-items: center; padding: 0.75rem 1.25rem; background: transparent; color: #e2e8f0; border-radius: 6px; border: 1px solid #1e1e2e; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.15s;"
            class="cta-secondary">
            Bundle &mdash; $39
          </a>
        </div>
      </div>
      <div>
        <TerminalWindow title="taskctl — today" content={`<span style="color:#4a5568">$ </span>taskctl today
<span style="color:#a0aec0">Tasks for today (3 due, 7 total)</span>

  <span style="color:#ef4444">!</span> <span style="color:#e2e8f0">Review Q3 budget proposal</span>     <span style="color:#4a5568">09:00</span>
  <span style="color:#f59e0b">~</span> <span style="color:#e2e8f0">Reply to Alice re: design review</span>  <span style="color:#4a5568">14:00</span>
  <span style="color:#f59e0b">~</span> <span style="color:#e2e8f0">Update ROADMAP.md</span>              <span style="color:#4a5568">EOD</span>
  <span style="color:#4a5568">&#x25CB;</span> <span style="color:#718096">Weekly team sync prep</span>
  <span style="color:#4a5568">&#x25CB;</span> <span style="color:#718096">Test mailctl v0.4.0</span>

<span style="color:#4a5568">$ </span>taskctl pomodoro --task 1
<span style="color:#f59e0b">&#x25B6;</span> <span style="color:#a0aec0">Pomodoro started: Review Q3 budget</span>
<span style="color:#4a5568">  [&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2588;] 25:00</span><span class="cursor-blink" style="color:#f59e0b">&#x2588;</span>`} />
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section style="padding: 4rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 800; color: #e2e8f0; margin: 0 0 2.5rem; letter-spacing: -0.02em;">Features</h2>
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;" class="features-grid">
        {features.map((feat: {title: string; desc: string}) => (
          <div style="background: #0a0a0f; border: 1px solid #1e1e2e; border-radius: 8px; padding: 1.5rem; transition: border-color 0.2s;" class="feature-card">
            <h3 style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; font-weight: 700; color: #f59e0b; margin: 0 0 0.5rem;">{feat.title}</h3>
            <p style="color: #718096; font-size: 0.875rem; line-height: 1.6; margin: 0;">{feat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHEATSHEET -->
  <section style="padding: 4rem 1.5rem; max-width: 1100px; margin: 0 auto;">
    <h2 style="font-size: 1.5rem; font-weight: 800; color: #e2e8f0; margin: 0 0 2rem; letter-spacing: -0.02em;">Command Reference</h2>
    <TerminalWindow title="taskctl — cheatsheet" content={`<span style="color:#4a5568"># Show today's tasks</span>
<span style="color:#4a5568">$ </span>taskctl today

<span style="color:#4a5568"># TUI task manager</span>
<span style="color:#4a5568">$ </span>taskctl tui

<span style="color:#4a5568"># Add a task</span>
<span style="color:#4a5568">$ </span>taskctl add <span style="color:#a0aec0">"Review PR #42"</span> --due today
<span style="color:#4a5568">$ </span>taskctl add <span style="color:#a0aec0">"Write docs"</span> --due 2026-07-10 --priority high

<span style="color:#4a5568"># Complete tasks</span>
<span style="color:#4a5568">$ </span>taskctl done --id 1
<span style="color:#4a5568">$ </span>taskctl done --all-today

<span style="color:#4a5568"># Pomodoro timer</span>
<span style="color:#4a5568">$ </span>taskctl pomodoro
<span style="color:#4a5568">$ </span>taskctl pomodoro --task 1

<span style="color:#4a5568"># Sync with Apple Reminders</span>
<span style="color:#4a5568">$ </span>taskctl sync

<span style="color:#4a5568"># Start daemon</span>
<span style="color:#4a5568">$ </span>taskctl daemon start

<span style="color:#4a5568"># Start MCP server</span>
<span style="color:#4a5568">$ </span>taskctl mcp`} />
  </section>

  <!-- MCP TOOLS -->
  <section style="padding: 4rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 800; color: #e2e8f0; margin: 0 0 0.5rem; letter-spacing: -0.02em;">MCP Tools</h2>
      <p style="color: #718096; font-size: 0.875rem; margin: 0 0 2rem;">Available via <code style="font-family: 'JetBrains Mono', monospace; background: #0a0a0f; padding: 0.1em 0.4em; border-radius: 3px; color: #f59e0b;">taskctl mcp</code></p>
      <div style="border: 1px solid #1e1e2e; border-radius: 8px; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="background: #0a0a0f; border-bottom: 1px solid #1e1e2e;">
              <th style="text-align: left; padding: 0.75rem 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #4a5568; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; width: 35%;">Tool</th>
              <th style="text-align: left; padding: 0.75rem 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #4a5568; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;">Description</th>
            </tr>
          </thead>
          <tbody>
            {mcpTools.map((tool: {name: string; desc: string}, i: number) => (
              <tr style={`background: ${i % 2 === 0 ? '#111118' : '#0d0d14'}; border-bottom: 1px solid #1e1e2e;`}>
                <td style="padding: 0.75rem 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; word-break: break-word; color: #f59e0b;">{tool.name}</td>
                <td style="padding: 0.75rem 1.25rem; font-size: 0.875rem; color: #718096;">{tool.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- PRICING CTA -->
  <section style="padding: 5rem 1.5rem; text-align: center; max-width: 600px; margin: 0 auto;">
    <h2 style="font-size: 1.75rem; font-weight: 800; color: #e2e8f0; margin: 0 0 1rem; letter-spacing: -0.02em;">
      Ready to give your AI hands?
    </h2>
    <p style="color: #718096; font-size: 1rem; line-height: 1.65; margin: 0 0 2rem;">
      One-time purchase. No subscriptions. Future updates included. Your data stays on your machine.
    </p>
    <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
      <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
        style="display: inline-flex; align-items: center; padding: 0.875rem 1.5rem; background: #f59e0b; color: #0a0a0f; border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 700; text-decoration: none; transition: all 0.15s; box-shadow: 0 4px 20px rgba(245,158,11,0.2);"
        class="cta-primary">
        Get taskctl &mdash; $9
      </a>
      <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
        style="display: inline-flex; align-items: center; padding: 0.875rem 1.5rem; background: transparent; color: #e2e8f0; border-radius: 6px; border: 1px solid #1e1e2e; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.15s;"
        class="cta-secondary">
        Or get the Bundle &mdash; $39
      </a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr !important; }
    .features-grid { grid-template-columns: 1fr !important; }
  }
  .cta-primary:hover { background: #d97706 !important; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(245,158,11,0.3) !important; }
  .cta-secondary:hover { border-color: rgba(245,158,11,0.3) !important; color: #f59e0b !important; }
  .feature-card:hover { border-color: rgba(245,158,11,0.2) !important; }
</style>
