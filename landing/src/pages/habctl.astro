---
import Layout from '../components/Layout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';

const mcpTools = [
  { name: "list_habits", desc: "List all habits with current streak and today's check-in status" },
  { name: "check_habit", desc: "Check in a habit for today (or a specific date)" },
  { name: "uncheck_habit", desc: "Undo a check-in — correct an accidental entry" },
  { name: "add_habit", desc: "Add a new habit to track" },
  { name: "delete_habit", desc: "Delete a habit and all its check-in history" },
  { name: "get_habit_stats", desc: "Detailed statistics for one or all habits over a time window" },
  { name: "streak_at_risk", desc: "List habits not yet checked in today that have an active streak" },
  { name: "get_weekly_summary", desc: "Habit completion summary for the last 7 days" },
  { name: "get_weekly_review", desc: "Per-habit data for 7 and 30 days — input for an AI coaching briefing" },
  { name: "suggest_habits", desc: "AI-suggested new habits based on the user's goals and existing habits" },
  { name: "add_checkin_note", desc: "Add or update a text note on a habit's check-in" },
  { name: "list_chains", desc: "List habit chains — pairs where finishing one suggests the next" },
];
const features = [
  { title: "Daily Check-ins with Streaks", desc: "Mark habits done each day. habctl tracks your current streak and longest streak automatically. Miss a day and the streak resets — simple accountability." },
  { title: "AI Weekly Coaching Review", desc: "habctl review pulls 7 and 30-day completion data and has Claude (or GPT, Gemini, Ollama) write a coaching briefing — what's sticking, what's slipping, what to focus on next." },
  { title: "Habit Chains & Streak Alerts", desc: "Link habits into chains so finishing one nudges the next. streak_at_risk flags active streaks you haven't checked in today, before you lose them." },
  { title: "MCP Server for AI Access", desc: "12 MCP tools let Claude check streaks, log or undo check-ins, run weekly reviews, and suggest new habits — enabling fully automated coaching and digests." },
];
---

<Layout
  title="habctl — Daily Habit Tracking for Terminal People"
  description="habctl — Track daily habits with streaks, AI weekly coaching reviews, and habit chains. 12 MCP tools for Claude Desktop."
  type="software"
  appName="habctl"
  appPrice="9"
>
  <!-- HERO -->
  <section style="padding: 10rem 1.5rem 5rem; max-width: 1100px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="hero-grid">
      <div>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #84cc16; margin-bottom: 1rem; letter-spacing: 0.1em; text-transform: uppercase;">
          missionctl suite &middot; macOS + Linux
        </div>
        <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.03em; color: #e2e8f0; margin: 0 0 1rem;">
          <span style="font-family: 'JetBrains Mono', monospace; color: #84cc16;">habctl</span>
        </h1>
        <p style="font-size: 1.25rem; font-weight: 600; color: #e2e8f0; margin: 0 0 0.75rem;">Daily habit tracking for terminal people</p>
        <p style="color: #718096; font-size: 1rem; line-height: 1.65; margin: 0 0 2rem;">Track daily habits with streaks, heatmaps, and AI weekly coaching reviews — all from your terminal. Claude can check in habits, flag at-risk streaks, and write a coaching briefing via 12 MCP tools.</p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
            style="display: inline-flex; align-items: center; padding: 0.75rem 1.25rem; background: #84cc16; color: #0a0a0f; border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 700; text-decoration: none; transition: all 0.15s;"
            class="cta-primary">
            Get habctl &mdash; $9
          </a>
          <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
            style="display: inline-flex; align-items: center; padding: 0.75rem 1.25rem; background: transparent; color: #e2e8f0; border-radius: 6px; border: 1px solid #1e1e2e; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.15s;"
            class="cta-secondary">
            Bundle &mdash; $39
          </a>
        </div>
      </div>
      <div>
        <TerminalWindow title="habctl — list" content={`<span style="color:#4a5568">$ </span>habctl list
<span style="color:#84cc16">Habits</span>                          <span style="color:#4a5568">streak  today  30d</span>
<span style="color:#e2e8f0">Sport                           </span><span style="color:#00d97e">12 days</span>  <span style="color:#00d97e">✓</span>     <span style="color:#00d97e">███████████████░░░░░</span> 77%
<span style="color:#e2e8f0">Read 30 min                     </span><span style="color:#00d97e"> 5 days</span>  <span style="color:#00d97e">✓</span>     <span style="color:#00d97e">█████████████░░░░░░░</span> 67%
<span style="color:#e2e8f0">No sugar                        </span><span style="color:#84cc16"> 2 days</span>  <span style="color:#718096">–</span>     <span style="color:#84cc16">████████░░░░░░░░░░░░</span> 43%

<span style="color:#4a5568">$ </span>habctl check <span style="color:#a0aec0">"No sugar"</span>
<span style="color:#00d97e">✓</span> <span style="color:#a0aec0">Checked in: No sugar  (streak: 3 days)</span><span class="cursor-blink" style="color:#84cc16">█</span>`} />
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section style="padding: 4rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 800; color: #e2e8f0; margin: 0 0 2.5rem; letter-spacing: -0.02em;">Features</h2>
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;" class="features-grid">
        {features.map((feat: {title: string; desc: string}) => (
          <div style="background: #0a0a0f; border: 1px solid #1e1e2e; border-radius: 8px; padding: 1.5rem; transition: border-color 0.2s;" class="feature-card">
            <h3 style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; font-weight: 700; color: #84cc16; margin: 0 0 0.5rem;">{feat.title}</h3>
            <p style="color: #718096; font-size: 0.875rem; line-height: 1.6; margin: 0;">{feat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHEATSHEET -->
  <section style="padding: 4rem 1.5rem; max-width: 1100px; margin: 0 auto;">
    <h2 style="font-size: 1.5rem; font-weight: 800; color: #e2e8f0; margin: 0 0 2rem; letter-spacing: -0.02em;">Command Reference</h2>
    <TerminalWindow title="habctl — cheatsheet" content={`<span style="color:#4a5568"># Add a new habit</span>
<span style="color:#4a5568">$ </span>habctl add <span style="color:#a0aec0">"Sport"</span>
<span style="color:#4a5568">$ </span>habctl add <span style="color:#a0aec0">"Read 30 min"</span>

<span style="color:#4a5568"># Check in for today</span>
<span style="color:#4a5568">$ </span>habctl check <span style="color:#a0aec0">"Sport"</span>
<span style="color:#4a5568">$ </span>habctl check <span style="color:#a0aec0">"Sport"</span> <span style="color:#6366f1">--date</span> 2026-07-10   <span style="color:#4a5568"># backfill a date</span>

<span style="color:#4a5568"># List all habits with streaks and 30-day bars</span>
<span style="color:#4a5568">$ </span>habctl list
<span style="color:#4a5568">$ </span>habctl list <span style="color:#6366f1">--format</span> diary                <span style="color:#4a5568"># diaryctl integration</span>

<span style="color:#4a5568"># Detailed stats for a habit</span>
<span style="color:#4a5568">$ </span>habctl stats <span style="color:#a0aec0">"Sport"</span>

<span style="color:#4a5568"># AI weekly coaching review</span>
<span style="color:#4a5568">$ </span>habctl review

<span style="color:#4a5568"># AI habit suggestions</span>
<span style="color:#4a5568">$ </span>habctl suggest <span style="color:#6366f1">--goal</span> <span style="color:#a0aec0">"more focus, less screen time"</span>

<span style="color:#4a5568"># Start MCP server</span>
<span style="color:#4a5568">$ </span>habctl mcp`} />
  </section>

  <!-- MCP TOOLS -->
  <section style="padding: 4rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 800; color: #e2e8f0; margin: 0 0 0.5rem; letter-spacing: -0.02em;">MCP Tools</h2>
      <p style="color: #718096; font-size: 0.875rem; margin: 0 0 2rem;">Available via <code style="font-family: 'JetBrains Mono', monospace; background: #0a0a0f; padding: 0.1em 0.4em; border-radius: 3px; color: #84cc16;">habctl mcp</code></p>
      <div style="border: 1px solid #1e1e2e; border-radius: 8px; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="background: #0a0a0f; border-bottom: 1px solid #1e1e2e;">
              <th style="text-align: left; padding: 0.75rem 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #4a5568; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; width: 35%;">Tool</th>
              <th style="text-align: left; padding: 0.75rem 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #4a5568; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;">Description</th>
            </tr>
          </thead>
          <tbody>
            {mcpTools.map((tool: {name: string; desc: string}, i: number) => (
              <tr style={`background: ${i % 2 === 0 ? '#111118' : '#0d0d14'}; border-bottom: 1px solid #1e1e2e;`}>
                <td style="padding: 0.75rem 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; word-break: break-word; color: #84cc16;">{tool.name}</td>
                <td style="padding: 0.75rem 1.25rem; font-size: 0.875rem; color: #718096;">{tool.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- PRICING CTA -->
  <section style="padding: 5rem 1.5rem; text-align: center; max-width: 600px; margin: 0 auto;">
    <h2 style="font-size: 1.75rem; font-weight: 800; color: #e2e8f0; margin: 0 0 1rem; letter-spacing: -0.02em;">
      Build habits that stick.
    </h2>
    <p style="color: #718096; font-size: 1rem; line-height: 1.65; margin: 0 0 2rem;">
      One-time purchase. No subscriptions. Future updates included. Your data stays on your machine.
    </p>
    <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
      <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
        style="display: inline-flex; align-items: center; padding: 0.875rem 1.5rem; background: #84cc16; color: #0a0a0f; border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 700; text-decoration: none; transition: all 0.15s; box-shadow: 0 4px 20px rgba(132,204,22,0.2);"
        class="cta-primary">
        Get habctl &mdash; $9
      </a>
      <a href="https://polar.sh/aeon022" target="_blank" rel="noopener"
        style="display: inline-flex; align-items: center; padding: 0.875rem 1.5rem; background: transparent; color: #e2e8f0; border-radius: 6px; border: 1px solid #1e1e2e; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.15s;"
        class="cta-secondary">
        Or get the Bundle &mdash; $39
      </a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr !important; }
    .features-grid { grid-template-columns: 1fr !important; }
  }
  .cta-primary:hover { background: #65a30d !important; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(132,204,22,0.3) !important; }
  .cta-secondary:hover { border-color: rgba(132,204,22,0.3) !important; color: #84cc16 !important; }
  .feature-card:hover { border-color: rgba(132,204,22,0.2) !important; }
</style>
