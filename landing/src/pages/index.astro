---
import Layout from '../components/Layout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import AppCard from '../components/AppCard.astro';
import PricingCard from '../components/PricingCard.astro';

const apps = [
  {
    name: 'mailctl',
    href: '/mailctl',
    description: 'Read inbox, compose and send email via Apple Mail. AI draft replies with one keystroke.',
    mcpCount: 6,
    features: ['TUI inbox with threading', 'AI draft reply (a-key)', 'Full-text search', 'MCP server for AI access'],
  },
  {
    name: 'calctl',
    href: '/calctl',
    description: 'Browse calendar, create events, find free slots via Apple Calendar. Summarize meetings with Claude.',
    mcpCount: 7,
    features: ['TUI week/month view', 'Apple Calendar sync', 'Free slot finder', 'Meeting summaries via Claude'],
  },
  {
    name: 'taskctl',
    href: '/taskctl',
    description: 'Manage tasks with Apple Reminders sync, Pomodoro timer, and background daemon.',
    mcpCount: 7,
    features: ['Apple Reminders sync', 'Built-in Pomodoro timer', 'Batch task operations', 'Background daemon mode'],
  },
  {
    name: 'notectl',
    href: '/notectl',
    description: 'Obsidian vault notes and daily notes via MCP. Works on macOS and Linux.',
    mcpCount: 7,
    features: ['Obsidian vault support', 'Daily note automation', 'Full-text search', 'Tag-based filtering'],
  },
  {
    name: 'budgetctl',
    href: '/budgetctl',
    description: 'Import bank CSV, categorize transactions, set budget goals. Claude auto-categorizes with --ai flag.',
    mcpCount: 9,
    features: ['N26, ING, DKB CSV import', 'AI auto-categorization', 'Budget goals with progress', 'Recurring payment detection'],
  },
  {
    name: 'diaryctl',
    href: '/diaryctl',
    description: 'Reads git history and generates AI narrative diary entries. Syncs back to Obsidian vault automatically.',
    mcpCount: 5,
    features: ['Git history reader', 'AI narrative entries', 'Obsidian write-back', 'Export for postctl pipeline'],
  },
  {
    name: 'timectl',
    href: '/timectl',
    description: 'Start/stop timers, weekly bar chart, live TUI. Link timers to tasks, navigate days, generate invoices.',
    mcpCount: 4,
    features: ['taskctl integration (T-key)', 'Invoice export (--month)', 'Day navigation (←/→/t)', 'Daily goal bar'],
  },
  {
    name: 'habctl',
    href: '/habctl',
    description: 'Track daily habits with streaks, check-ins, and automatic diary integration.',
    mcpCount: 3,
    features: ['Daily check-ins with streaks', '30-day progress bars', 'Diary template integration', 'MCP server for AI access'],
  },
  {
    name: 'postctl',
    href: 'https://postctl.sh',
    description: 'Schedule social media posts to Threads, Bluesky, Mastodon, and other platforms from your terminal.',
    mcpCount: 7,
    features: ['Threads, Bluesky, Mastodon, X, LinkedIn', 'Safe remote post deletion', 'Spam/ban protection queue', 'MCP tools for AI posting'],
  },
];

const mcpConfig = `{
  "mcpServers": {
    "mailctl":   { "command": "mailctl",   "args": ["mcp"] },
    "calctl":    { "command": "calctl",    "args": ["mcp"] },
    "taskctl":   { "command": "taskctl",   "args": ["mcp"] },
    "notectl":   { "command": "notectl",   "args": ["mcp"] },
    "budgetctl": { "command": "budgetctl", "args": ["mcp"] },
    "diaryctl":  { "command": "diaryctl",  "args": ["mcp"] },
    "timectl":   { "command": "timectl",   "args": ["mcp"] },
    "habctl":    { "command": "habctl",    "args": ["mcp"] },
    "postctl":   { "command": "postctl",   "args": ["mcp"] }
  }
}`;

const workflows = [
  {
    title: 'Morning Briefing',
    cmd: 'AI + mailctl + calctl + taskctl',
    description: "AI reads your unread emails, checks today's calendar, and surfaces the 3 most important tasks — in one prompt.",
  },
  {
    title: 'Weekly Planning',
    cmd: 'AI + calctl + taskctl + notectl',
    description: 'AI reviews your weekly notes, finds free slots, and drafts a prioritized task list synced to Apple Reminders.',
  },
  {
    title: 'Monthly Finance Review',
    cmd: 'AI + budgetctl',
    description: 'Import your bank CSV, let AI categorize transactions and surface anomalies, then write a summary to your Obsidian vault.',
  },
  {
    title: 'End-of-Day Digest',
    cmd: 'AI + diaryctl + timectl + habctl',
    description: 'AI checks your time log, habit streaks, and git commits, then writes a diary entry and surfaces what to finish before tomorrow.',
  },
];

// Tool grid data
const toolGroups = [
  {
    app: 'mailctl', count: 6, color: '#00d97e',
    tools: [
      { name: 'inbox',      desc: 'List recent inbox messages with sender, subject, preview' },
      { name: 'search_email', desc: 'Search by keyword across subject, sender, body' },
      { name: 'email_thread', desc: 'Get all messages in a thread matched by subject' },
      { name: 'send_email', desc: 'Send an email via Apple Mail' },
      { name: 'draft_email', desc: 'Save a composed message to Apple Mail Drafts' },
      { name: 'sync_inbox', desc: 'Sync from Apple Mail into local cache' },
    ],
  },
  {
    app: 'calctl', count: 7, color: '#6366f1',
    tools: [
      { name: 'list_events',     desc: 'List events between two dates' },
      { name: 'today',           desc: "Today's events" },
      { name: 'this_week',       desc: "This week's events (Monday to Sunday)" },
      { name: 'find_free_slots', desc: 'Find free time within working hours' },
      { name: 'create_event',    desc: 'Create a calendar event' },
      { name: 'delete_event',    desc: 'Delete an event by title and date' },
      { name: 'sync',            desc: 'Sync from Apple Calendar into local cache' },
    ],
  },
  {
    app: 'taskctl', count: 7, color: '#f59e0b',
    tools: [
      { name: 'today_tasks', desc: 'Tasks due today or overdue' },
      { name: 'week_tasks',  desc: 'Tasks due this week' },
      { name: 'list_tasks',  desc: 'List tasks, filter by list or status' },
      { name: 'sync',        desc: 'Sync from Apple Reminders into local cache' },
      { name: 'create_task', desc: 'Create task with title, list, due date, notes' },
      { name: 'complete_task', desc: 'Mark a task completed' },
      { name: 'delete_task', desc: 'Delete a task' },
    ],
  },
  {
    app: 'notectl', count: 7, color: '#a78bfa',
    tools: [
      { name: 'list_notes',      desc: 'List notes from cache (filter: folder, source)' },
      { name: 'read_note',       desc: 'Read full note content by title' },
      { name: 'write_note',      desc: 'Create or update a note in the vault' },
      { name: 'search_notes',    desc: 'Keyword search across title and content' },
      { name: 'sync_notes',      desc: 'Sync Obsidian vault into cache' },
      { name: 'get_daily_note',  desc: "Get today's daily note (creates from template if missing)" },
      { name: 'append_daily_note', desc: 'Append content under a named section' },
    ],
  },
  {
    app: 'budgetctl', count: 9, color: '#10b981',
    tools: [
      { name: 'list_transactions', desc: 'List transactions, filter by month/category/query' },
      { name: 'budget_summary',    desc: 'Monthly income/expenses/net with category breakdown' },
      { name: 'import_transactions', desc: 'Import from a bank CSV file' },
      { name: 'tag_transactions',  desc: 'Create a category rule (pattern → category)' },
      { name: 'apply_category_rules', desc: 'Re-apply all rules to all transactions' },
      { name: 'list_budget_goals', desc: 'Goals with current-month spending progress' },
      { name: 'set_budget_goal',   desc: 'Set a monthly spending limit for a category' },
      { name: 'delete_budget_goal', desc: 'Remove a goal' },
      { name: 'detect_recurring_payments', desc: 'Detect subscriptions and recurring charges' },
    ],
  },
  {
    app: 'diaryctl', count: 5, color: '#f59e0b',
    tools: [
      { name: 'get_today_stats',    desc: 'Git commits, files changed, suite data (tasks, events, time tracked) for today' },
      { name: 'get_diary_entry',    desc: 'Read a diary entry by date (default: today)' },
      { name: 'write_diary_entry',  desc: 'Save or overwrite a diary entry — used by Claude to fill in the narrative' },
      { name: 'get_coding_stats',   desc: 'Aggregate stats for last N days: streak, commits, most active day, repo breakdown' },
      { name: 'list_diary_entries', desc: 'List recent entries with date and preview' },
    ],
  },
  {
    app: 'timectl', count: 4, color: '#6366f1',
    tools: [
      { name: 'start_timer',    desc: 'Start a timer with task name and optional project tag' },
      { name: 'stop_timer',     desc: 'Stop the running timer, returns task name and duration' },
      { name: 'get_time_log',   desc: 'Time entries for a date or date range with total duration' },
      { name: 'get_time_stats', desc: 'Breakdown by task/project, daily average, streak for last N days' },
    ],
  },
  {
    app: 'habctl', count: 3, color: '#f59e0b',
    tools: [
      { name: 'check_habit',     desc: 'Check in for a habit today (or a specific date)' },
      { name: 'list_habits',     desc: 'List all habits with today\'s check-in status and current streak' },
      { name: 'get_habit_stats', desc: 'Streak, longest streak, and 30-day completion rate for a habit' },
    ],
  },
  {
    app: 'postctl', count: 7, color: '#ec4899',
    tools: [
      { name: 'list_posts',     desc: 'List posts, filter by platform/status/campaign' },
      { name: 'get_post',       desc: 'Get a single post by ID with full content' },
      { name: 'create_post',    desc: 'Create a draft or scheduled post' },
      { name: 'publish_post',   desc: 'Publish a post immediately' },
      { name: 'schedule_post',  desc: "Update a post's scheduled time" },
      { name: 'list_campaigns', desc: 'List campaigns with post counts and status breakdown' },
      { name: 'get_campaign',   desc: 'Get all posts in a campaign with full content' },
    ],
  },
];

const faqs = [
  {
    q: 'Do I need a Claude subscription?',
    a: 'Yes, Claude Pro or Team. missionctl connects to Claude Desktop via MCP — no extra subscription needed beyond that.',
  },
  {
    q: 'Does it work on Linux?',
    a: 'notectl and budgetctl work on macOS and Linux. mailctl, calctl, and taskctl require macOS (they bridge Apple Mail, Calendar, and Reminders).',
  },
  {
    q: 'Is my data safe?',
    a: 'All data stays on your machine. missionctl never calls any external server. The only network calls are what you explicitly trigger (sending an email, publishing a post).',
  },
  {
    q: "What if Apple Mail/Calendar isn't running?",
    a: 'mailctl and calctl launch Apple Mail and Calendar in the background via AppleScript if they aren\'t open. No manual intervention needed.',
  },
  {
    q: 'Can I use it without the TUI?',
    a: 'Yes. Every tool has a full CLI (mailctl inbox --json, taskctl today, etc.). The TUI is the default but optional.',
  },
  {
    q: 'How do I get updates?',
    a: 'Updates are included with your purchase. Pull the latest from GitHub and re-run ./setup.sh.',
  },
  {
    q: "What's the difference between buying individually vs. the bundle?",
    a: 'The bundle ($39) includes all 9 tools. Buying individually costs $81 total. If you use more than 4 tools, the bundle saves money.',
  },
];
---

<Layout
  title="missionctl — Give your AI hands"
  description="55 MCP tools across 9 terminal apps for macOS + Linux. Read email, manage calendar, tasks, notes, budget, track habits, log time, keep a diary, and schedule posts. Local-first, no subscriptions."
>
  <!-- ======= HERO ======= -->
  <section style="min-height: calc(100vh - 92px); display: flex; flex-direction: column; justify-content: center; padding: 10rem 1.5rem 6rem; max-width: 1200px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="hero-grid">

      <!-- Left: Text -->
      <div>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #00d97e; margin-bottom: 1rem; letter-spacing: 0.1em; text-transform: uppercase;">
          55 MCP tools &middot; 9 terminal apps &middot; macOS + Linux
        </div>
        <h1 style="font-size: clamp(2.5rem, 5vw, 3.75rem); font-weight: 900; line-height: 1.08; letter-spacing: -0.03em; color: #e2e8f0; margin: 0 0 1.25rem;">
          Give your AI<br>
          <span style="color: #00d97e; text-shadow: 0 0 40px rgba(0,217,126,0.3);">hands.</span>
        </h1>
        <p style="font-size: 1.125rem; color: #718096; line-height: 1.65; margin: 0 0 2rem; max-width: 480px;">
          55 MCP tools across 9 terminal apps. Local-first. No subscriptions.
          Your AI can now read email, manage your calendar, handle tasks, write notes, track spending, log time, track habits, keep a diary, and schedule posts.
        </p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <a
            href="https://polar.sh/aeon022"
            target="_blank"
            rel="noopener"
            style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.5rem; background: #00d97e; color: #0a0a0f; border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 700; text-decoration: none; transition: all 0.15s ease; box-shadow: 0 4px 20px rgba(0,217,126,0.2);"
            class="hero-cta-primary"
          >
            Get the Bundle &mdash; $39
          </a>
          <a
            href="#apps"
            style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.5rem; background: transparent; color: #e2e8f0; border-radius: 6px; border: 1px solid #1e1e2e; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.15s ease;"
            class="hero-cta-secondary"
          >
            Browse Apps &darr;
          </a>
        </div>
        <p style="color: #4a5568; font-size: 0.75rem; margin: 1.25rem 0 0; font-family: 'JetBrains Mono', monospace;">
          One-time purchase &middot; Future updates included &middot; Your data stays on your machine
        </p>
      </div>

      <!-- Right: Terminal (typewriter) -->
      <div>
        <TerminalWindow id="hero-terminal" title="~ missionctl" content={`<span class="cursor-blink" style="color:#00d97e">&#x2588;</span>`} />
      </div>

    </div>
  </section>

  <!-- ======= THE IDEA ======= -->
  <section style="padding: 5rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 900px; margin: 0 auto; text-align: center;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #e2e8f0; margin: 0 0 1rem; letter-spacing: -0.02em;">
        AI is great at planning.<br>
        <span style="color: #718096;">It's bad at doing — because it has no hands.</span>
      </h2>
      <p style="color: #718096; font-size: 1rem; line-height: 1.7; max-width: 600px; margin: 0 auto;">
        missionctl gives your AI hands. Each app runs locally on your machine and exposes MCP tools that Claude (or any MCP client) can call directly — no cloud, no subscriptions, no data leaving your computer.
      </p>
    </div>
  </section>

  <!-- ======= HOW IT WORKS ======= -->
  <section style="padding: 5rem 1.5rem; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: #e2e8f0; margin: 0 0 0.75rem; letter-spacing: -0.02em;">
        How it works
      </h2>
      <p style="color: #718096; font-size: 1rem; max-width: 500px; margin: 0 auto;">
        AI plans. missionctl executes. Your data stays local.
      </p>
    </div>

    <!-- Steps -->
    <div style="display: flex; align-items: stretch; justify-content: center; gap: 0; flex-wrap: wrap;" class="how-steps">

      <!-- Step 1 -->
      <div class="how-card">
        <div class="how-step-num">01</div>
        <h3 class="how-title">You ask Claude</h3>
        <p class="how-desc">
          "Give me a morning briefing"<br>
          "Schedule a launch campaign"
        </p>
      </div>

      <div class="how-arrow">──&rarr;</div>

      <!-- Step 2 -->
      <div class="how-card how-card--accent">
        <div class="how-step-num">02</div>
        <h3 class="how-title" style="color:#00d97e;">Claude calls MCP tools</h3>
        <p class="how-desc">
          55 tools across 9 apps,<br>running locally on your machine
        </p>
      </div>

      <div class="how-arrow">──&rarr;</div>

      <!-- Step 3 -->
      <div class="how-card">
        <div class="how-step-num">03</div>
        <h3 class="how-title">missionctl acts</h3>
        <p class="how-desc">
          Reads Apple Mail, creates calendar events,<br>writes to your Obsidian vault
        </p>
      </div>

      <div class="how-arrow">──&rarr;</div>

      <!-- Step 4 -->
      <div class="how-card">
        <div class="how-step-num">04</div>
        <h3 class="how-title" style="color:#f59e0b;">Apple APIs / Files</h3>
        <p class="how-desc">
          Mail, Calendar, Reminders,<br>Obsidian, CSV exports
        </p>
      </div>

    </div>
  </section>

  <!-- ======= APPS GRID ======= -->
  <section id="apps" style="padding: 5rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;">
        <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: #e2e8f0; margin: 0 0 0.75rem; letter-spacing: -0.02em;">
          Nine apps. One config block.
        </h2>
        <p style="color: #718096; font-size: 1rem; max-width: 500px; margin: 0 auto;">
          Each tool stands alone or works together as part of the missionctl suite.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;" class="apps-grid">
        {apps.map(app => (
          <AppCard
            name={app.name}
            description={app.description}
            href={app.href}
            mcpCount={app.mcpCount}
            features={app.features}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ======= 43-TOOL GRID ======= -->
  <section style="padding: 5rem 1.5rem; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: #e2e8f0; margin: 0 0 0.75rem; letter-spacing: -0.02em;">
        55 tools. One config.
      </h2>
      <p style="color: #718096; font-size: 1rem; max-width: 500px; margin: 0 auto;">
        Hover any chip to see what it does. Every tool is callable from Claude Desktop.
      </p>
    </div>

    {toolGroups.map(group => (
      <div style="margin-bottom: 2.5rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.875rem;">
          <span style={`font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: ${group.color};`}>
            {group.app}
          </span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #4a5568; background: #111118; border: 1px solid #1e1e2e; padding: 0.15rem 0.5rem; border-radius: 20px;">
            {group.count} tools
          </span>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
          {group.tools.map(tool => (
            <span class={`tool-chip app-${group.app}`}>
              {tool.name}
              <span class="tool-tooltip">{tool.desc}</span>
            </span>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- ======= MCP SECTION ======= -->
  <section style="padding: 5rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 900px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;">
        <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: #e2e8f0; margin: 0 0 0.75rem; letter-spacing: -0.02em;">
          Plug in in 2 minutes
        </h2>
        <p style="color: #718096; font-size: 1rem; max-width: 500px; margin: 0 auto;">
          Add this to your <code style="font-family: 'JetBrains Mono', monospace; background: #0a0a0f; padding: 0.1em 0.4em; border-radius: 3px; font-size: 0.9em; color: #00d97e;">claude_desktop_config.json</code> and restart Claude Desktop.
        </p>
      </div>

      <TerminalWindow title="claude_desktop_config.json" content={`<span style="color:#a0aec0">${mcpConfig.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>`} />

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem;" class="mcp-stats-grid">
        {[
          { n: '55', label: 'MCP tools total' },
          { n: '9', label: 'local-first apps' },
          { n: '0', label: 'cloud dependencies' },
        ].map(stat => (
          <div style="text-align: center; padding: 1.25rem; background: #0a0a0f; border: 1px solid #1e1e2e; border-radius: 8px;">
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 800; color: #00d97e;">{stat.n}</div>
            <div style="color: #718096; font-size: 0.8rem; margin-top: 0.25rem;">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======= AI WORKFLOWS ======= -->
  <section style="padding: 5rem 1.5rem; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: #e2e8f0; margin: 0 0 0.75rem; letter-spacing: -0.02em;">
        Real AI workflows
      </h2>
      <p style="color: #718096; font-size: 1rem; max-width: 500px; margin: 0 auto;">
        Cross-app workflows that actually work — because the tools are already connected.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="workflows-grid">
      {workflows.map(w => (
        <article style="background: #111118; border: 1px solid #1e1e2e; border-radius: 8px; padding: 1.5rem; transition: border-color 0.2s;" class="workflow-card">
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #00d97e; margin-bottom: 0.75rem; letter-spacing: 0.05em;">
            {w.cmd}
          </div>
          <h3 style="font-size: 1rem; font-weight: 700; color: #e2e8f0; margin: 0 0 0.75rem;">{w.title}</h3>
          <p style="color: #718096; font-size: 0.875rem; line-height: 1.6; margin: 0;">{w.description}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ======= FAQ ======= -->
  <section style="padding: 5rem 1.5rem; background: #111118; border-top: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e;">
    <div style="max-width: 720px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;">
        <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: #e2e8f0; margin: 0 0 0.75rem; letter-spacing: -0.02em;">
          Frequently asked
        </h2>
      </div>

      <div class="faq-list">
        {faqs.map((item, i) => (
          <div class="faq-item" data-index={i}>
            <button class="faq-question" aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer">
              <p class="faq-answer-text">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
