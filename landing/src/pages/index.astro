<script>
  // ── Typewriter animation ────────────────────────────────────
  interface Segment { text: string; color?: string; blink?: boolean; }

  const lines: Segment[][] = [
    [{ text: '$ ', color: '#4a5568' }, { text: 'mailctl sync && taskctl today', color: '#e2e8f0' }],
    [{ text: '✓', color: '#00d97e' }, { text: ' Synced 12 messages', color: '#a0aec0' }],
    [{ text: '✓', color: '#00d97e' }, { text: ' 3 tasks due today', color: '#a0aec0' }],
    [],
    [{ text: '$ ', color: '#4a5568' }, { text: 'calctl free ', color: '#e2e8f0' }, { text: '--from', color: '#6366f1' }, { text: ' today ', color: '#e2e8f0' }, { text: '--to', color: '#6366f1' }, { text: ' +7d', color: '#e2e8f0' }],
    [{ text: 'Free slots:', color: '#a0aec0' }],
    [{ text: '  Mon', color: '#f59e0b' }, { text: ' 09:00–11:00', color: '#e2e8f0' }],
    [{ text: '  Wed', color: '#f59e0b' }, { text: ' 14:00–16:00', color: '#e2e8f0' }],
    [],
    [{ text: '$ ', color: '#4a5568' }, { text: 'budgetctl summary ', color: '#e2e8f0' }, { text: '--month', color: '#6366f1' }, { text: ' 2026-07', color: '#e2e8f0' }],
    [{ text: 'Income:   ', color: '#a0aec0' }, { text: '€4,200.00', color: '#00d97e' }],
    [{ text: 'Expenses: ', color: '#a0aec0' }, { text: '€2,847.35', color: '#ef4444' }],
    [{ text: 'Saved:    ', color: '#a0aec0' }, { text: '€1,352.65 (32.2%)', color: '#00d97e' }, { text: '█', color: '#00d97e', blink: true }],
  ];

  function runTypewriter(pre: HTMLElement) {
    // Clear initial cursor placeholder
    pre.innerHTML = '';

    let lineIdx = 0, segIdx = 0, charIdx = 0;
    let currentSpan: HTMLElement | null = null;

    function typeNext() {
      if (lineIdx >= lines.length) return;

      const line = lines[lineIdx];

      if (line.length === 0) {
        pre.appendChild(document.createTextNode('\n'));
        lineIdx++;
        segIdx = 0; charIdx = 0;
        setTimeout(typeNext, 320 + Math.random() * 180);
        return;
      }

      if (segIdx >= line.length) {
        pre.appendChild(document.createTextNode('\n'));
        lineIdx++;
        segIdx = 0; charIdx = 0;
        currentSpan = null;
        setTimeout(typeNext, 280 + Math.random() * 200);
        return;
      }

      const seg = line[segIdx];

      if (charIdx === 0) {
        currentSpan = document.createElement('span');
        if (seg.color) currentSpan.style.color = seg.color;
        if (seg.blink) currentSpan.className = 'cursor-blink';
        pre.appendChild(currentSpan);
      }

      if (currentSpan) currentSpan.textContent += seg.text[charIdx];
      charIdx++;

      if (charIdx >= seg.text.length) {
        segIdx++; charIdx = 0; currentSpan = null;
      }

      setTimeout(typeNext, 28 + Math.random() * 22);
    }

    typeNext();
  }

  // Start when terminal enters viewport
  const terminal = document.getElementById('hero-terminal');
  const pre = terminal?.querySelector('pre');

  if (pre) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          obs.disconnect();
          setTimeout(() => runTypewriter(pre as HTMLElement), 400);
        }
      },
      { threshold: 0.3 }
    );
    obs.observe(terminal!);
  }

  // ── FAQ accordion ───────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest<HTMLElement>('.faq-item');
      if (!item) return;
      const wasOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        const q = i.querySelector('.faq-question');
        if (q) q.setAttribute('aria-expanded', 'false');
      });
      // Toggle clicked
      if (!wasOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
