---
export interface Props {
  name: string;
  description: string;
  href: string;
  mcpCount: number;
  features: string[];
}

const { name, description, href, mcpCount, features } = Astro.props;
---

<article style="
  background: #111118;
  border: 1px solid #1e1e2e;
  border-radius: 8px;
  padding: 1.5rem;
  position: relative;
  transition: border-color 0.2s, box-shadow 0.2s;
  display: flex;
  flex-direction: column;
  gap: 1rem;
" class="app-card">

  <!-- Corner decorations -->
  <span style="position: absolute; top: -1px; left: -1px; font-family: monospace; font-size: 11px; color: #00d97e40; line-height: 1;">+</span>
  <span style="position: absolute; top: -1px; right: -1px; font-family: monospace; font-size: 11px; color: #00d97e40; line-height: 1;">+</span>
  <span style="position: absolute; bottom: -1px; left: -1px; font-family: monospace; font-size: 11px; color: #00d97e40; line-height: 1;">+</span>
  <span style="position: absolute; bottom: -1px; right: -1px; font-family: monospace; font-size: 11px; color: #00d97e40; line-height: 1;">+</span>

  <!-- Header -->
  <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem;">
    <h3 style="
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      font-weight: 700;
      color: #00d97e;
      margin: 0;
    ">{name}</h3>
    <span style="
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      padding: 0.2rem 0.5rem;
      background: rgba(0,217,126,0.08);
      border: 1px solid rgba(0,217,126,0.2);
      border-radius: 20px;
      color: #00d97e;
      white-space: nowrap;
    ">{mcpCount} MCP tools</span>
  </div>

  <!-- Description -->
  <p style="color: #718096; font-size: 0.875rem; line-height: 1.6; margin: 0;">{description}</p>

  <!-- Features -->
  <ul style="margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.4rem; flex: 1;">
    {features.map(f => (
      <li style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8rem; color: #4a5568;">
        <span style="color: #00d97e; font-family: monospace; flex-shrink: 0; margin-top: 1px;">&#x2713;</span>
        <span style="color: #a0aec0;">{f}</span>
      </li>
    ))}
  </ul>

  <!-- Link -->
  <a href={href} style="
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #00d97e;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: gap 0.15s;
    margin-top: auto;
  " class="card-link">
    Learn more <span>&rarr;</span>
  </a>
</article>

<style>
  .app-card:hover {
    border-color: rgba(0, 217, 126, 0.3) !important;
    box-shadow: 0 0 20px rgba(0, 217, 126, 0.05) !important;
  }

  .app-card:hover .card-link {
    gap: 0.5rem !important;
  }
</style>
