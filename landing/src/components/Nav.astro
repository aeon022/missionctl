---
const apps = [
  { name: 'mailctl', href: '/mailctl' },
  { name: 'calctl', href: '/calctl' },
  { name: 'taskctl', href: '/taskctl' },
  { name: 'notectl', href: '/notectl' },
  { name: 'budgetctl', href: '/budgetctl' },
  { name: 'diaryctl', href: '/diaryctl' },
  { name: 'timectl', href: '/timectl' },
  { name: 'habctl', href: '/habctl' },
];

const currentPath = Astro.url.pathname;
---

<header id="main-nav" class="main-nav">
  <nav style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 56px;">
    <!-- Logo -->
    <a href="/" style="font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700; color: #00d97e; text-decoration: none; letter-spacing: -0.02em; flex-shrink: 0;">
      <span style="color: #e2e8f0;">mission</span>ctl
    </a>

    <!-- App links (desktop) -->
    <div style="display: flex; gap: 0.25rem; align-items: center;" class="nav-apps">
      {apps.map(app => (
        <a
          href={app.href}
          style={`
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            padding: 0.35rem 0.75rem;
            border-radius: 4px;
            text-decoration: none;
            transition: all 0.15s ease;
            color: ${currentPath === app.href ? '#00d97e' : '#718096'};
            background: ${currentPath === app.href ? 'rgba(0,217,126,0.08)' : 'transparent'};
          `}
          class="nav-link"
        >
          {app.name}
        </a>
      ))}
      <a
        href="https://postctl.sh"
        target="_blank"
        rel="noopener"
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; padding: 0.35rem 0.75rem; border-radius: 4px; text-decoration: none; transition: all 0.15s ease; color: #718096;"
        class="nav-link"
      >
        postctl ↗
      </a>
      <a
        href="/docs"
        style={`
          font-family: 'JetBrains Mono', monospace;
          font-size: 0.8rem;
          padding: 0.35rem 0.75rem;
          border-radius: 4px;
          text-decoration: none;
          transition: all 0.15s ease;
          color: ${currentPath.startsWith('/docs') ? '#00d97e' : '#718096'};
          background: ${currentPath.startsWith('/docs') ? 'rgba(0,217,126,0.08)' : 'transparent'};
        `}
        class="nav-link"
      >
        docs
      </a>
    </div>

    <!-- Buy button -->
    <a
      href="/#pricing"
      style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; font-weight: 600; padding: 0.5rem 1rem; background: #00d97e; color: #0a0a0f; border-radius: 4px; text-decoration: none; transition: all 0.15s ease; white-space: nowrap; flex-shrink: 0;"
      class="nav-buy"
    >
      Buy
    </a>
  </nav>
</header>

<!-- Spacer for fixed nav + announcement bar -->
<div class="nav-spacer"></div>

<style>
  .main-nav {
    position: relative; /* fixed by #site-header wrapper */
    background: rgba(10,10,15,0.0);
    border-bottom: 1px solid rgba(30,30,46,0.0);
    transition: background 0.2s ease, backdrop-filter 0.2s ease, border-color 0.2s ease;
  }

  .main-nav.scrolled {
    background: rgba(10,10,15,0.5);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(30,30,46,0.6);
  }

  .nav-spacer {
    height: 56px; /* spacer for nav only; site-header is the fixed element */
  }

  @media (max-width: 768px) {
    .nav-apps { display: none !important; }
  }

  /* ── Glitch + glow on hover ────────────────────────────── */
  @keyframes nav-glitch {
    0%   { text-shadow: -3px 0 #ff2d6e, 3px 0 #00d9ff; color: #a0aec0; }
    17%  { text-shadow:  3px 0 #ff2d6e, -3px 0 #00d9ff; color: #a0aec0; }
    34%  { text-shadow: -4px 0 #ff2d6e,  2px 0 #00d9ff; color: #c8fae6; }
    51%  { text-shadow:  2px 0 #ff2d6e, -4px 0 #00d9ff; color: #00d97e; }
    68%  { text-shadow:  0   0 12px rgba(0,217,126,0.9); color: #00d97e; }
    85%  { text-shadow:  0   0 16px rgba(0,217,126,0.7), 0 0 32px rgba(0,217,126,0.2); color: #00d97e; }
    100% { text-shadow:  0   0  8px rgba(0,217,126,0.45), 0 0 20px rgba(0,217,126,0.12); color: #00d97e; }
  }

  .nav-link:hover {
    color: #00d97e !important;
    background: rgba(0,217,126,0.05) !important;
    animation: nav-glitch 0.38s steps(6, end) forwards;
  }

  .nav-buy:hover {
    background: #00c070 !important;
    transform: translateY(-1px);
  }
</style>

<script>
  // Scroll-based nav blur
  const nav = document.getElementById('main-nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 20);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
