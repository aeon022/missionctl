---
const apps = [
  { name: 'mailctl',   href: '/mailctl',   color: '#00d97e' },
  { name: 'calctl',    href: '/calctl',    color: '#6366f1' },
  { name: 'taskctl',   href: '/taskctl',   color: '#f59e0b' },
  { name: 'notectl',   href: '/notectl',   color: '#a78bfa' },
  { name: 'budgetctl', href: '/budgetctl', color: '#10b981' },
  { name: 'diaryctl',  href: '/diaryctl',  color: '#fb923c' },
  { name: 'timectl',   href: '/timectl',   color: '#22d3ee' },
  { name: 'habctl',    href: '/habctl',    color: '#84cc16' },
  { name: 'postctl',   href: 'https://postctl.sh', color: '#ec4899', external: true },
];

const currentPath = Astro.url.pathname;
const isAppPage = apps.some(a => a.href === currentPath);
---

<header id="main-nav" class="main-nav">
  <nav style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 56px;">

    <!-- Logo -->
    <a href="/" style="font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700; color: #00d97e; text-decoration: none; letter-spacing: -0.02em; flex-shrink: 0;">
      <span style="color: #e2e8f0;">mission</span>ctl
    </a>

    <!-- Center: Home + Apps dropdown + Docs -->
    <div style="display: flex; gap: 0.5rem; align-items: center;" class="nav-center">

      <!-- Home -->
      <a
        href="/"
        class={`nav-link${currentPath === '/' ? ' nav-link--active' : ''}`}
      >
        home
      </a>

      <!-- Apps dropdown -->
      <div class="apps-dropdown" id="apps-dropdown">
        <button
          class={`apps-trigger${isAppPage ? ' is-active' : ''}`}
          id="apps-trigger"
          aria-haspopup="true"
          aria-expanded="false"
        >
          apps
          <svg class="apps-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <!-- Dropdown panel -->
        <div class="apps-panel" id="apps-panel" role="menu">
          <div class="apps-grid">
            {apps.map(app => (
              <a
                href={app.href}
                class="app-chip"
                style={`--chip-color: ${app.color};`}
                role="menuitem"
                {...(app.external ? { target: '_blank', rel: 'noopener' } : {})}
              >
                <span class="app-chip-dot"></span>
                {app.name}{app.external ? ' ↗' : ''}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Docs link -->
      <a
        href="/docs"
        class={`nav-link${currentPath.startsWith('/docs') ? ' nav-link--active' : ''}`}
      >
        docs
      </a>

    </div>

    <!-- Buy button -->
    <a
      href="/#pricing"
      class="nav-buy"
    >
      Buy
    </a>
  </nav>
</header>

<!-- Spacer for fixed nav + announcement bar -->
<div class="nav-spacer"></div>

<style>
  /* ── Nav shell ──────────────────────────────────────────── */
  .main-nav {
    position: relative;
    background: rgba(10,10,15,0.0);
    border-bottom: 1px solid rgba(30,30,46,0.0);
    transition: background 0.2s ease, backdrop-filter 0.2s ease, border-color 0.2s ease;
  }
  .main-nav.scrolled {
    background: rgba(10,10,15,0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(30,30,46,0.7);
  }
  .nav-spacer {
    height: 56px;
  }

  /* ── Shared link style ──────────────────────────────────── */
  .nav-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    text-decoration: none;
    color: #718096;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-link:hover,
  .nav-link--active {
    color: #00d97e;
    background: rgba(0,217,126,0.07);
  }

  /* ── Apps trigger button ────────────────────────────────── */
  .apps-trigger {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    padding: 0.35rem 0.65rem;
    border-radius: 4px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #718096;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .apps-trigger:hover,
  .apps-trigger.is-active,
  .apps-trigger[aria-expanded="true"] {
    color: #00d97e;
    background: rgba(0,217,126,0.07);
  }
  .apps-chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .apps-trigger[aria-expanded="true"] .apps-chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown container ─────────────────────────────────── */
  .apps-dropdown {
    position: relative;
  }

  /* ── Panel ──────────────────────────────────────────────── */
  .apps-panel {
    position: absolute;
    top: calc(100% + 2px);
    left: 50%;
    transform: translateX(-50%);
    width: 340px;
    background: rgba(10,10,15,0.97);
    border: 1px solid rgba(30,30,46,0.9);
    border-radius: 10px;
    padding: 0.75rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);

    /* invisible bridge fills the gap so mouse can travel from trigger → panel */
  /* hidden state */
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 100;
  }
  .apps-panel.open {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* arrow pointer */
  .apps-panel::before {
    content: '';
    position: absolute;
    top: -5px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 10px;
    height: 10px;
    background: rgba(10,10,15,0.97);
    border-left: 1px solid rgba(30,30,46,0.9);
    border-top: 1px solid rgba(30,30,46,0.9);
  }

  /* ── App grid ───────────────────────────────────────────── */
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
  }

  /* ── App chip ───────────────────────────────────────────── */
  .app-chip {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.65rem;
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    color: #a0aec0;
    border: 1px solid transparent;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .app-chip:hover {
    color: var(--chip-color);
    background: color-mix(in srgb, var(--chip-color) 8%, transparent);
    border-color: color-mix(in srgb, var(--chip-color) 20%, transparent);
  }
  .app-chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--chip-color);
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }
  .app-chip:hover .app-chip-dot {
    opacity: 1;
  }

  /* ── Buy button ─────────────────────────────────────────── */
  .nav-buy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    background: #00d97e;
    color: #0a0a0f;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nav-buy:hover {
    background: #00c070;
    transform: translateY(-1px);
  }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav-center { display: none !important; }
  }
</style>

<script>
  function initNav() {
    // ── Scroll blur ────────────────────────────────────────
    const nav = document.getElementById('main-nav');
    if (nav) {
      const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 20);
      window.removeEventListener('scroll', (window as any).__navScroll);
      (window as any).__navScroll = onScroll;
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // ── Apps dropdown ──────────────────────────────────────
    const trigger = document.getElementById('apps-trigger');
    const panel   = document.getElementById('apps-panel');
    const wrapper = document.getElementById('apps-dropdown');
    if (!trigger || !panel || !wrapper) return;

    // Remove old listeners by cloning nodes
    const newTrigger = trigger.cloneNode(true) as HTMLElement;
    const newWrapper = wrapper.cloneNode(false) as HTMLElement;
    // Re-attach panel and trigger into wrapper clone then swap
    // Simpler: just track with an abort controller
    const ac = new AbortController();
    const { signal } = ac;
    // Clean up previous controller if any
    const prev = (wrapper as any).__navAc as AbortController | undefined;
    if (prev) prev.abort();
    (wrapper as any).__navAc = ac;

    let closeTimer: ReturnType<typeof setTimeout> | null = null;

    const open = () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      panel.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
    };
    const scheduleClose = () => {
      closeTimer = setTimeout(() => {
        panel.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }, 140);
    };
    const cancelClose = () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    };
    const closeNow = () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      panel.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    };

    wrapper.addEventListener('mouseenter', open,          { signal });
    wrapper.addEventListener('mouseleave', scheduleClose, { signal });
    panel.addEventListener('mouseenter',   cancelClose,   { signal });
    panel.addEventListener('mouseleave',   scheduleClose, { signal });

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      panel.classList.contains('open') ? closeNow() : open();
    }, { signal });

    document.addEventListener('click', (e) => {
      if (!wrapper.contains(e.target as Node)) closeNow();
    }, { signal });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeNow();
    }, { signal });
  }

  // Run on first load and after every View Transition navigation
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
